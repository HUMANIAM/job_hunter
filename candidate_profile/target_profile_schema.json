{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "target_profile/target_profile.schema.json",
  "title": "Candidate Target Profile",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "profile"],
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "profile": {
      "$ref": "#/$defs/targetProfile"
    }
  },
  "$defs": {
    "stringArray": {
      "type": "array",
      "items": { "type": "string" },
      "uniqueItems": true
    },
    "seniorityHint": {
      "enum": ["intern", "junior", "medior", "senior", "lead", "staff", "principal", null]
    },
    "targetProfile": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "role_families",
        "preferred_locations",
        "allowed_workplace_types",
        "required_languages",
        "excluded_seniority_levels",
        "required_restrictions_absent",
        "preferred_skills",
        "preferred_domains"
      ],
      "properties": {
        "role_families": {
          "$ref": "#/$defs/stringArray"
        },
        "preferred_locations": {
          "$ref": "#/$defs/stringArray"
        },
        "allowed_workplace_types": {
          "$ref": "#/$defs/stringArray"
        },
        "required_languages": {
          "$ref": "#/$defs/stringArray"
        },
        "excluded_seniority_levels": {
          "type": "array",
          "items": { "$ref": "#/$defs/seniorityHint" },
          "uniqueItems": true
        },
        "required_restrictions_absent": {
          "$ref": "#/$defs/stringArray"
        },
        "preferred_skills": {
          "$ref": "#/$defs/stringArray"
        },
        "preferred_domains": {
          "$ref": "#/$defs/stringArray"
        }
      }
    }
  }
}
