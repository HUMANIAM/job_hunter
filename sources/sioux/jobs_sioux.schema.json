{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "sources/sioux/jobs_sioux.schema.json",
  "title": "Sioux Kept Jobs Payload",
  "description": "Schema for the final kept-jobs artifact written to jobs_sioux.json.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "fetched_at_unix",
    "source",
    "configured_countries",
    "configured_languages",
    "total_jobs",
    "relevant_jobs",
    "jobs"
  ],
  "properties": {
    "fetched_at_unix": {
      "type": "integer"
    },
    "source": {
      "type": "string"
    },
    "configured_countries": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "configured_languages": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "total_jobs": {
      "type": "integer",
      "minimum": 0
    },
    "relevant_jobs": {
      "type": "integer",
      "minimum": 0
    },
    "jobs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/siouxJob"
      }
    }
  },
  "$defs": {
    "nullableString": {
      "type": [
        "string",
        "null"
      ]
    },
    "nullableInteger": {
      "type": [
        "integer",
        "null"
      ]
    },
    "nullableBoolean": {
      "type": [
        "boolean",
        "null"
      ]
    },
    "stringArray": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "seniorityHint": {
      "enum": [
        "junior",
        "medior",
        "senior",
        "lead",
        "principal",
        "staff",
        null
      ]
    },
    "llmExtraction": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "required_skills",
        "preferred_skills",
        "required_languages",
        "preferred_languages",
        "required_protocols",
        "preferred_protocols",
        "required_standards",
        "preferred_standards",
        "required_domains",
        "preferred_domains",
        "seniority_hint",
        "restrictions",
        "evidence"
      ],
      "properties": {
        "required_skills": {
          "$ref": "#/$defs/siouxJob/properties/required_skills"
        },
        "preferred_skills": {
          "$ref": "#/$defs/siouxJob/properties/preferred_skills"
        },
        "required_languages": {
          "$ref": "#/$defs/siouxJob/properties/required_languages"
