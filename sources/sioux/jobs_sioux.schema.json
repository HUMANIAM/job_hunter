{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "sources/sioux/jobs_sioux.schema.json",
  "title": "Sioux Kept Jobs Payload",
  "description": "Schema for the final kept-jobs artifact written to jobs_sioux.json.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "fetched_at_unix",
    "source",
    "configured_countries",
    "configured_languages",
    "total_jobs",
    "relevant_jobs",
    "jobs"
  ],
  "properties": {
    "fetched_at_unix": {
      "type": "integer"
    },
    "source": {
      "type": "string"
    },
    "configured_countries": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "configured_languages": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "total_jobs": {
      "type": "integer",
      "minimum": 0
    },
    "relevant_jobs": {
      "type": "integer",
      "minimum": 0
    },
    "jobs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/siouxJob"
      }
    }
  },
  "$defs": {
    "nullableString": {
      "type": [
        "string",
        "null"
      ]
    },
    "nullableInteger": {
      "type": [
        "integer",
        "null"
      ]
    },
    "nullableBoolean": {
      "type": [
        "boolean",
        "null"
      ]
    },
    "stringArray": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "confidenceScore": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "requirementLevel": {
      "enum": [
        "required",
        "preferred"
      ]
    },
    "nullableRequirementLevel": {
      "enum": [
        "required",
        "preferred",
        null
      ]
    },
    "sourceKind": {
      "enum": [
        "llm",
        "regex_text",
        "html_tag",
        "json_ld",
        "derived_text",
        "visible_text",
        "title_match"
      ]
    },
    "nullableSourceKind": {
      "enum": [
        "llm",
        "regex_text",
        "html_tag",
        "json_ld",
        "derived_text",
        "visible_text",
        "title_match",
        null
      ]
    },
    "seniorityHint": {
      "enum": [
        "junior",
        "medior",
        "senior",
        "lead",
        "principal",
        "staff",
        null
      ]
    },
    "llmFeatureItem": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "requirement_level",
        "confidence",
        "evidence"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "requirement_level": {
          "$ref": "#/$defs/requirementLevel"
        },
        "confidence": {
          "$ref": "#/$defs/confidenceScore"
        },
        "evidence": {
          "$ref": "#/$defs/stringArray"
        }
      }
    },
    "jobFeatureItem": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "requirement_level",
        "confidence",
        "evidence",
        "source_kind"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "requirement_level": {
          "$ref": "#/$defs/requirementLevel"
        },
        "confidence": {
          "$ref": "#/$defs/confidenceScore"
        },
        "evidence": {
          "$ref": "#/$defs/stringArray"
        },
        "source_kind": {
          "$ref": "#/$defs/sourceKind"
        }
      }
    },
    "llmRestrictionItem": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "value",
        "confidence",
        "evidence"
      ],
      "properties": {
        "value": {
          "type": "string"
        },
        "confidence": {
          "$ref": "#/$defs/confidenceScore"
        },
        "evidence": {
          "$ref": "#/$defs/stringArray"
        }
      }
    },
    "jobRestrictionItem": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "value",
        "confidence",
        "evidence",
        "source_kind"
      ],
      "properties": {
        "value": {
          "type": "string"
        },
        "confidence": {
          "$ref": "#/$defs/confidenceScore"
        },
        "evidence": {
          "$ref": "#/$defs/stringArray"
        },
        "source_kind": {
          "$ref": "#/$defs/sourceKind"
        }
      }
    },
    "llmSeniorityItem": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "value",
        "confidence",
        "evidence"
      ],
      "properties": {
        "value": {
          "$ref": "#/$defs/seniorityHint"
        },
        "confidence": {
          "$ref": "#/$defs/confidenceScore"
        },
        "evidence": {
          "$ref": "#/$defs/stringArray"
        }
      }
    },
    "jobSeniorityItem": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "value",
        "confidence",
        "evidence",
        "source_kind"
      ],
      "properties": {
        "value": {
          "$ref": "#/$defs/seniorityHint"
        },
        "confidence": {
          "$ref": "#/$defs/confidenceScore"
        },
        "evidence": {
          "$ref": "#/$defs/stringArray"
        },
        "source_kind": {
          "$ref": "#/$defs/nullableSourceKind"
        }
      }
    },
    "jobYearsExperienceRequirement": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "min_years",
        "max_years",
        "requirement_level",
        "confidence",
        "evidence",
        "source_kind"
      ],
      "properties": {
        "min_years": {
          "$ref": "#/$defs/nullableInteger"
        },
        "max_years": {
          "$ref": "#/$defs/nullableInteger"
        },
        "requirement_level": {
          "$ref": "#/$defs/nullableRequirementLevel"
        },
        "confidence": {
          "$ref": "#/$defs/confidenceScore"
        },
        "evidence": {
          "$ref": "#/$defs/stringArray"
        },
        "source_kind": {
          "$ref": "#/$defs/nullableSourceKind"
        }
      }
    },
    "llmExtraction": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "skills",
        "languages",
        "protocols",
        "standards",
        "domains",
        "seniority",
        "restrictions"
      ],
      "properties": {
        "skills": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/llmFeatureItem"
          }
        },
        "languages": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/llmFeatureItem"
          }
        },
        "protocols": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/llmFeatureItem"
          }
        },
        "standards": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/llmFeatureItem"
          }
        },
        "domains": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/llmFeatureItem"
          }
        },
        "seniority": {
          "$ref": "#/$defs/llmSeniorityItem"
        },
        "restrictions": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/llmRestrictionItem"
          }
        }
      }
    },
    "siouxJobDeterministicContext": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "title",
        "url",
        "disciplines",
        "location",
        "team",
        "work_experience",
        "min_years_experience",
        "max_years_experience",
        "experience_text",
        "educational_background",
        "required_degrees",
        "industry_domains",
        "workplace_type",
        "fulltime_parttime",
        "min_hours_per_week",
        "max_hours_per_week",
        "remote_policy",
        "work_locations_text",
        "client_site_required",
        "travel_region",
        "recruiter_name",
        "recruiter_role",
        "recruiter_email",
        "recruiter_phone"
      ],
      "properties": {
        "title": {
          "$ref": "#/$defs/siouxJob/properties/title"
        },
        "url": {
          "$ref": "#/$defs/siouxJob/properties/url"
        },
        "disciplines": {
          "$ref": "#/$defs/siouxJob/properties/disciplines"
        },
        "location": {
          "$ref": "#/$defs/siouxJob/properties/location"
        },
        "team": {
          "$ref": "#/$defs/siouxJob/properties/team"
        },
        "work_experience": {
          "$ref": "#/$defs/siouxJob/properties/work_experience"
        },
        "min_years_experience": {
          "$ref": "#/$defs/nullableInteger"
        },
        "max_years_experience": {
          "$ref": "#/$defs/nullableInteger"
        },
        "experience_text": {
          "$ref": "#/$defs/nullableString"
        },
        "educational_background": {
          "$ref": "#/$defs/siouxJob/properties/educational_background"
        },
        "required_degrees": {
          "$ref": "#/$defs/siouxJob/properties/required_degrees"
        },
        "industry_domains": {
          "$ref": "#/$defs/siouxJob/properties/industry_domains"
        },
        "workplace_type": {
          "$ref": "#/$defs/siouxJob/properties/workplace_type"
        },
        "fulltime_parttime": {
          "$ref": "#/$defs/siouxJob/properties/fulltime_parttime"
        },
        "min_hours_per_week": {
          "$ref": "#/$defs/siouxJob/properties/min_hours_per_week"
        },
        "max_hours_per_week": {
          "$ref": "#/$defs/siouxJob/properties/max_hours_per_week"
        },
        "remote_policy": {
          "$ref": "#/$defs/siouxJob/properties/remote_policy"
        },
        "work_locations_text": {
          "$ref": "#/$defs/siouxJob/properties/work_locations_text"
        },
        "client_site_required": {
          "$ref": "#/$defs/siouxJob/properties/client_site_required"
        },
        "travel_region": {
          "$ref": "#/$defs/siouxJob/properties/travel_region"
        },
        "recruiter_name": {
          "$ref": "#/$defs/siouxJob/properties/recruiter_name"
        },
        "recruiter_role": {
          "$ref": "#/$defs/siouxJob/properties/recruiter_role"
        },
        "recruiter_email": {
          "$ref": "#/$defs/siouxJob/properties/recruiter_email"
        },
        "recruiter_phone": {
          "$ref": "#/$defs/siouxJob/properties/recruiter_phone"
        }
      }
    },
    "siouxJob": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "job_id",
        "title",
        "url",
        "disciplines",
        "location",
        "team",
        "work_experience",
        "years_experience_requirement",
        "educational_background",
        "required_degrees",
        "skills",
        "languages",
        "protocols",
        "standards",
        "industry_domains",
        "domains",
        "workplace_type",
        "fulltime_parttime",
        "min_hours_per_week",
        "max_hours_per_week",
        "remote_policy",
        "work_locations_text",
        "client_site_required",
        "travel_region",
        "recruiter_name",
        "recruiter_role",
        "recruiter_email",
        "recruiter_phone",
        "seniority",
        "restrictions",
        "description_text"
      ],
      "properties": {
        "job_id": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "url": {
          "type": "string"
        },
        "disciplines": {
          "$ref": "#/$defs/stringArray"
        },
        "location": {
          "$ref": "#/$defs/nullableString"
        },
        "team": {
          "$ref": "#/$defs/nullableString"
        },
        "work_experience": {
          "$ref": "#/$defs/nullableString"
        },
        "years_experience_requirement": {
          "$ref": "#/$defs/jobYearsExperienceRequirement"
        },
        "educational_background": {
          "$ref": "#/$defs/nullableString"
        },
        "required_degrees": {
          "$ref": "#/$defs/stringArray"
        },
        "skills": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/jobFeatureItem"
          }
        },
        "languages": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/jobFeatureItem"
          }
        },
        "protocols": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/jobFeatureItem"
          }
        },
        "standards": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/jobFeatureItem"
          }
        },
        "industry_domains": {
          "$ref": "#/$defs/stringArray"
        },
        "domains": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/jobFeatureItem"
          }
        },
        "workplace_type": {
          "$ref": "#/$defs/nullableString"
        },
        "fulltime_parttime": {
          "$ref": "#/$defs/nullableString"
        },
        "min_hours_per_week": {
          "$ref": "#/$defs/nullableInteger"
        },
        "max_hours_per_week": {
          "$ref": "#/$defs/nullableInteger"
        },
        "remote_policy": {
          "$ref": "#/$defs/nullableString"
        },
        "work_locations_text": {
          "$ref": "#/$defs/nullableString"
        },
        "client_site_required": {
          "$ref": "#/$defs/nullableBoolean"
        },
        "travel_region": {
          "$ref": "#/$defs/nullableString"
        },
        "recruiter_name": {
          "$ref": "#/$defs/nullableString"
        },
        "recruiter_role": {
          "$ref": "#/$defs/nullableString"
        },
        "recruiter_email": {
          "$ref": "#/$defs/nullableString"
        },
        "recruiter_phone": {
          "$ref": "#/$defs/nullableString"
        },
        "seniority": {
          "$ref": "#/$defs/jobSeniorityItem"
        },
        "restrictions": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/jobRestrictionItem"
          }
        },
        "description_text": {
          "type": "string"
        }
      }
    }
  }
}
